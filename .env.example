# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web Push (PWA) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@incluhub.in

# Email fallback (Resend) — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=IncluPilot <notifications@yourdomain.com>
APP_BASE_URL=https://inclu-pilot-three.vercel.app

# Comma-separated Google emails allowed to become the platform manager (documentation only;
# the live allowlist is stored in Supabase platform_config.allowed_manager_emails)
ALLOWED_MANAGER_EMAILS=you@gmail.com
